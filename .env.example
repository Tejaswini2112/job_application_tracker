# Copy to backend/.env and fill in values.
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_application_tracker"

# Backend API (Express)
PORT=5000
JWT_SECRET="change-this-to-a-long-random-string-in-production"

