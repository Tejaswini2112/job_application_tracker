# PostgreSQL (Render: use Internal Database URL for the API service in same region)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Render injects PORT; optional locally
PORT=5000

# Listen address — use 0.0.0.0 on Render/Docker (default in app)
# HOST=0.0.0.0

# At least 16 characters
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# Comma-separated frontend URLs (required when NODE_ENV=production)
# FRONTEND_ORIGIN=https://your-frontend.onrender.com
# FRONTEND_ORIGIN=https://app.example.com,https://www.example.com

# NODE_ENV=development
